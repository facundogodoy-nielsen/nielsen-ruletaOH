<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Ruleta Nielsen</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@700;900&display=swap" rel="stylesheet">
<style>
*{-webkit-box-sizing:border-box;box-sizing:border-box;margin:0;padding:0;
  -webkit-tap-highlight-color:transparent;}
html,body{width:100%;height:100%;overflow:hidden;
  font-family:'Nunito',sans-serif;-webkit-text-size-adjust:100%;}

#bg{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;
  background-size:cover;background-position:center;background-repeat:no-repeat;}
#bgOverlay{position:fixed;top:0;left:0;width:100%;height:100%;z-index:1;
  background:-webkit-linear-gradient(top,
    rgba(10,18,30,.80) 0%,rgba(12,22,36,.26) 34%,
    rgba(12,22,36,.26) 66%,rgba(10,18,30,.86) 100%);
  background:linear-gradient(180deg,
    rgba(10,18,30,.80) 0%,rgba(12,22,36,.26) 34%,
    rgba(12,22,36,.26) 66%,rgba(10,18,30,.86) 100%);}

#app{position:fixed;top:0;left:0;width:100%;height:100%;z-index:2;
  display:-webkit-box;display:-webkit-flex;display:flex;
  -webkit-flex-direction:column;flex-direction:column;
  -webkit-align-items:center;align-items:center;
  padding:8px 10px 10px 10px;}

#header{width:100%;
  display:-webkit-box;display:-webkit-flex;display:flex;
  -webkit-align-items:center;align-items:center;
  -webkit-justify-content:center;justify-content:center;
  background:rgba(255,255,255,.94);border-radius:14px;
  padding:9px 16px;
  box-shadow:0 4px 20px rgba(0,0,0,.4),0 0 0 2px rgba(232,97,44,.30);
  margin-bottom:6px;}
.hlogo{-webkit-flex:1;flex:1;
  display:-webkit-box;display:-webkit-flex;display:flex;
  -webkit-align-items:center;align-items:center;
  -webkit-justify-content:center;justify-content:center;padding:0 6px;}
.hlogo img{max-height:60px;max-width:100%;display:block;object-fit:contain;}
.hsep{width:1px;height:54px;-webkit-flex-shrink:0;flex-shrink:0;
  background:-webkit-linear-gradient(top,transparent,rgba(232,97,44,.6),transparent);
  background:linear-gradient(180deg,transparent,rgba(232,97,44,.6),transparent);}

#row{display:-webkit-box;display:-webkit-flex;display:flex;
  -webkit-flex-direction:row;flex-direction:row;
  -webkit-align-items:center;align-items:center;
  -webkit-justify-content:center;justify-content:center;
  -webkit-flex:1 1 auto;flex:1 1 auto;
  min-height:0;width:100%;}

#titulo{width:82px;-webkit-flex-shrink:0;flex-shrink:0;
  font-family:'Bebas Neue',sans-serif;font-size:clamp(15px,3vw,22px);
  letter-spacing:3px;color:#fff;text-align:center;line-height:1.5;
  text-shadow:0 2px 16px rgba(232,97,44,.95),0 0 40px rgba(232,97,44,.4);}

#wheelZone{display:-webkit-box;display:-webkit-flex;display:flex;
  -webkit-align-items:center;align-items:center;
  -webkit-justify-content:center;justify-content:center;
  -webkit-flex:1 1 auto;flex:1 1 auto;min-width:0;min-height:0;}

#wheelOuter{position:relative;-webkit-flex-shrink:0;flex-shrink:0;
  width:80vmin;height:80vmin;max-width:580px;max-height:580px;}

#rim{position:absolute;
  top:-13px;left:-13px;right:-13px;bottom:-13px;
  border-radius:50%;z-index:0;
  background:#b03a10;
  box-shadow:0 0 0 3px rgba(255,120,50,.5),
    0 0 50px rgba(232,97,44,.85),
    0 0 100px rgba(232,97,44,.40);}

#pointer{position:absolute;top:-30px;left:50%;
  -webkit-transform:translateX(-50%);transform:translateX(-50%);z-index:3;
  -webkit-filter:drop-shadow(0 4px 10px rgba(232,97,44,1));
  filter:drop-shadow(0 4px 10px rgba(232,97,44,1));}

/* SVG DE LA RULETA — reemplaza al canvas */
#wheelSvg{display:block;position:relative;z-index:1;
  width:100%;height:100%;border-radius:50%;
  -webkit-touch-callout:none;touch-action:none;}
#wheelGroup{
  -webkit-transform-origin:100px 100px;transform-origin:100px 100px;
  -webkit-transform-box:view-box;transform-box:view-box;
  -webkit-transform:rotate(0deg);transform:rotate(0deg);}

#hub{position:absolute;top:50%;left:50%;z-index:2;
  -webkit-transform:translate(-50%,-50%);transform:translate(-50%,-50%);
  width:14%;height:14%;min-width:40px;min-height:40px;
  max-width:60px;max-height:60px;border-radius:50%;
  background:-webkit-radial-gradient(circle at 38% 35%,#fff 0%,#ff9a5a 35%,#c04e1e 80%);
  background:radial-gradient(circle at 38% 35%,#fff 0%,#ff9a5a 35%,#c04e1e 80%);
  box-shadow:0 0 22px rgba(232,97,44,.9),0 4px 14px rgba(0,0,0,.5);
  border:3px solid rgba(255,255,255,.55);}

#btnWrap{width:82px;-webkit-flex-shrink:0;flex-shrink:0;
  display:-webkit-box;display:-webkit-flex;display:flex;
  -webkit-align-items:center;align-items:center;
  -webkit-justify-content:center;justify-content:center;}
#btnSpin{background:-webkit-linear-gradient(135deg,#E8612C 0%,#c04e1e 100%);
  background:linear-gradient(135deg,#E8612C 0%,#c04e1e 100%);
  border:none;outline:none;color:#fff;
  font-family:'Bebas Neue',sans-serif;font-size:clamp(15px,2.5vw,22px);
  letter-spacing:4px;padding:20px 14px;border-radius:16px;cursor:pointer;
  box-shadow:0 8px 30px rgba(232,97,44,.70),0 2px 8px rgba(0,0,0,.4);
  -webkit-writing-mode:vertical-rl;writing-mode:vertical-rl;
  -webkit-text-orientation:mixed;text-orientation:mixed;
  touch-action:manipulation;width:66px;}
#btnSpin:active{opacity:.80;}
#btnSpin:disabled{opacity:.40;}

#overlay{position:fixed;top:0;left:0;width:100%;height:100%;z-index:100;
  background:rgba(0,0,0,.80);display:none;
  -webkit-align-items:center;align-items:center;
  -webkit-justify-content:center;justify-content:center;
  -webkit-backdrop-filter:blur(5px);backdrop-filter:blur(5px);}
#overlay.show{display:-webkit-box;display:-webkit-flex;display:flex;}
#resultCard{background:-webkit-linear-gradient(145deg,#1a2535f2,#0f1820f2);
  background:linear-gradient(145deg,#1a2535f2,#0f1820f2);
  border:2px solid #E8612C;border-radius:24px;
  padding:30px 36px;text-align:center;max-width:340px;width:88%;
  box-shadow:0 0 60px rgba(232,97,44,.50),0 20px 60px rgba(0,0,0,.6);}
#resEmoji{font-size:68px;line-height:1;margin-bottom:10px;}
#resTag{font-family:'Bebas Neue',sans-serif;font-size:12px;
  letter-spacing:4px;color:#E8612C;margin-bottom:4px;}
#resText{font-family:'Bebas Neue',sans-serif;font-size:32px;
  color:#fff;letter-spacing:2px;line-height:1.2;margin-bottom:22px;}
#btnClose{background:#E8612C;color:#fff;border:none;
  font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:3px;
  padding:12px 40px;border-radius:50px;cursor:pointer;
  box-shadow:0 4px 16px rgba(232,97,44,.5);touch-action:manipulation;}

#confettiLayer{position:fixed;top:0;left:0;width:100%;height:100%;
  pointer-events:none;z-index:99;overflow:hidden;}
.confetti-piece{position:absolute;width:10px;height:5px;
  -webkit-transform:translate3d(0,0,0);transform:translate3d(0,0,0);
  will-change:transform;}
</style>
</head>
