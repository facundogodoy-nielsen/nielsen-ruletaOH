<script>
var IMG_N  = '';
var IMG_I  = '';
var IMG_L  = '';
var IMG_BG = '';

document.getElementById('imgN').src = 'data:image/png;base64,' + IMG_N;
document.getElementById('imgI').src = 'data:image/png;base64,' + IMG_I;
document.getElementById('imgL').src = 'data:image/png;base64,' + IMG_L;
document.getElementById('bg').style.backgroundImage = "url('data:image/jpeg;base64," + IMG_BG + "')";

/* ── Datos de segmentos (orden debe coincidir con SVG generado) ── */
var SEGS = [
  {em:'\uD83D\uDCF8', label:'FOTO CON EL EQUIPO', prize:true },
  {em:'\uD83D\uDE05', label:'SIGA PARTICIPANDO',  prize:false},
  {em:'\uD83C\uDF81', label:'PREMIO SORPRESA',    prize:true },
  {em:'\uD83D\uDE05', label:'SIGA PARTICIPANDO',  prize:false},
  {em:'\uD83C\uDFC6', label:'PREMIO MAYOR',       prize:true },
  {em:'\uD83D\uDD04', label:'ERROR 404 INTENTALO OTRA VEZ', prize:false},
  {em:'\uD83D\uDE05', label:'SIGA PARTICIPANDO',  prize:false},
  {em:'\uD83C\uDF9F', label:'VALE CORTESIA',      prize:true }
];
var N   = SEGS.length;
var ARC = 360 / N;

var wheelGroup = document.getElementById('wheelGroup');
var angle = 0;
var spinning = false;

/* ── Girar mediante transform rotate en SVG (súper compatible iOS) ── */
function easeOut(t) { return 1 - Math.pow(1 - t, 4.5); }

function spin() {
  if (spinning) return;
  spinning = true;
  document.getElementById('btnSpin').disabled = true;

  var extraDeg  = (5 + Math.floor(Math.random() * 6)) * 360;
  var stopDeg   = Math.random() * 360;
  var totalDeg  = extraDeg + stopDeg;
  var duration  = 4000 + Math.random() * 1800;
  var t0 = performance.now();
  var a0 = angle;

  function frame(now) {
    var t = Math.min((now - t0) / duration, 1);
    angle = a0 + totalDeg * easeOut(t);
    var rotStr = 'rotate(' + angle + 'deg)';
    wheelGroup.style.webkitTransform = rotStr;
    wheelGroup.style.transform       = rotStr;
    if (t < 1) { requestAnimationFrame(frame); return; }
    angle = angle % 360;
    var rotStr = 'rotate(' + angle + 'deg)';
    wheelGroup.style.webkitTransform = rotStr;
    wheelGroup.style.transform       = rotStr;
    spinning = false;
    document.getElementById('btnSpin').disabled = false;
    showResult(angle);
  }
  requestAnimationFrame(frame);
}

function getWinner(deg) {
  /* La ruleta comienza con el primer sector en la parte de arriba (-90°).
     Después de rotar 'deg' grados, el sector en la flecha es: */
  var norm = ((-deg) % 360 + 360) % 360;
  var idx  = Math.floor(norm / ARC) % N;
  return SEGS[idx];
}

function showResult(deg) {
  var seg = getWinner(deg);
  document.getElementById('resEmoji').textContent = seg.em;
  document.getElementById('resText').textContent  = seg.label;
  document.getElementById('overlay').classList.add('show');
  if (seg.prize) confetti();
}

function onSpin(e)  { if (e.cancelable) e.preventDefault(); spin(); }
function onClose(e) { if (e.cancelable) e.preventDefault();
  document.getElementById('overlay').classList.remove('show'); }

document.getElementById('btnSpin').addEventListener('touchend', onSpin);
document.getElementById('btnSpin').addEventListener('click',    onSpin);
document.getElementById('btnClose').addEventListener('touchend', onClose);
document.getElementById('btnClose').addEventListener('click',    onClose);

/* ── Confetti con elementos DOM (no canvas) para compatibilidad iOS total ── */
function confetti() {
  var layer = document.getElementById('confettiLayer');
  var COLS = ['#E8612C','#F5C518','#fff','#c04e1e','#ff9a5a','#75aadb'];
  var W = window.innerWidth;
  var H = window.innerHeight;
  var pieces = [];

  for (var i = 0; i < 80; i++) {
    var p = document.createElement('div');
    p.className = 'confetti-piece';
    var sz = 5 + Math.random() * 8;
    p.style.width  = sz + 'px';
    p.style.height = (sz * 0.5) + 'px';
    p.style.background = COLS[Math.floor(Math.random() * COLS.length)];
    p.style.left = (Math.random() * W) + 'px';
    p.style.top  = (-20 - Math.random() * 100) + 'px';
    p.style.borderRadius = Math.random() > 0.5 ? '2px' : '50%';
    layer.appendChild(p);
    pieces.push({
      el: p,
      x: parseFloat(p.style.left),
      y: parseFloat(p.style.top),
      vx: (Math.random() - 0.5) * 6,
      vy: 2 + Math.random() * 4,
      rot: Math.random() * 360,
      rv: (Math.random() - 0.5) * 8
    });
  }

  var fr = 0;
  function loop() {
    for (var i = 0; i < pieces.length; i++) {
      var p = pieces[i];
      p.x += p.vx; p.y += p.vy; p.vy += 0.1; p.rot += p.rv;
      p.el.style.webkitTransform = 'translate(' + p.x + 'px,' + p.y + 'px) rotate(' + p.rot + 'deg)';
      p.el.style.transform       = 'translate(' + p.x + 'px,' + p.y + 'px) rotate(' + p.rot + 'deg)';
    }
    fr++;
    if (fr < 180) requestAnimationFrame(loop);
    else {
      for (var j = 0; j < pieces.length; j++) layer.removeChild(pieces[j].el);
    }
  }
  requestAnimationFrame(loop);
}
</script>
</body>
